<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boboboom.jxc.identity.infrastructure.persistence.mapper.RoleMenuRelMapper">

    <resultMap id="RoleMenuRelDOResultMap" type="com.boboboom.jxc.identity.infrastructure.persistence.dataobject.RoleMenuRelDO">
        <id property="id" column="id"/>
        <result property="roleId" column="role_id"/>
        <result property="menuId" column="menu_id"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectByRoleId" resultMap="RoleMenuRelDOResultMap">
        select id, role_id, menu_id, created_at
        from sys_role_menu_rel
        where role_id = #{roleId}
        order by id asc
    </select>
</mapper>


<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boboboom.jxc.identity.infrastructure.persistence.mapper.AuditLogMapper">

    <resultMap id="AuditLogDOResultMap" type="com.boboboom.jxc.identity.infrastructure.persistence.dataobject.AuditLogDO">
        <id property="id" column="id"/>
        <result property="operatorUserId" column="operator_user_id"/>
        <result property="operatorPhone" column="operator_phone"/>
        <result property="actionType" column="action_type"/>
        <result property="targetType" column="target_type"/>
        <result property="targetId" column="target_id"/>
        <result property="scopeType" column="scope_type"/>
        <result property="scopeId" column="scope_id"/>
        <result property="operationResult" column="operation_result"/>
        <result property="detailJson" column="detail_json"/>
        <result property="clientIp" column="client_ip"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="AuditLogViewMap" type="com.boboboom.jxc.identity.infrastructure.persistence.query.AuditLogView">
        <id property="id" column="id"/>
        <result property="operatorUserId" column="operator_user_id"/>
        <result property="operatorPhone" column="operator_phone"/>
        <result property="operatorRealName" column="operator_real_name"/>
        <result property="actionType" column="action_type"/>
        <result property="targetType" column="target_type"/>
        <result property="targetId" column="target_id"/>
        <result property="scopeType" column="scope_type"/>
        <result property="scopeId" column="scope_id"/>
        <result property="operationResult" column="operation_result"/>
        <result property="clientIp" column="client_ip"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectAuditViews" resultMap="AuditLogViewMap">
        select al.id,
               al.operator_user_id,
               al.operator_phone,
               u.real_name as operator_real_name,
               al.action_type,
               al.target_type,
               al.target_id,
               al.scope_type,
               al.scope_id,
               al.operation_result,
               al.client_ip,
               al.created_at
        from sys_audit_log al
                 left join sys_user u on u.id = al.operator_user_id
        <where>
            <if test="operatorUserId != null">
                al.operator_user_id = #{operatorUserId}
            </if>
            <if test="actionType != null and actionType != ''">
                and al.action_type = #{actionType}
            </if>
            <if test="targetType != null and targetType != ''">
                and al.target_type = #{targetType}
            </if>
        </where>
        order by al.created_at desc
        limit #{limit}
    </select>
</mapper>


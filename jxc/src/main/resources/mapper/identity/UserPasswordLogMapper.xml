<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boboboom.jxc.identity.infrastructure.persistence.mapper.UserPasswordLogMapper">

    <resultMap id="UserPasswordLogDOResultMap" type="com.boboboom.jxc.identity.infrastructure.persistence.dataobject.UserPasswordLogDO">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="operationType" column="operation_type"/>
        <result property="operatorUserId" column="operator_user_id"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectRecentByUserId" resultMap="UserPasswordLogDOResultMap">
        select id, user_id, operation_type, operator_user_id, password_hash, remark, created_at
        from sys_user_password_log
        where user_id = #{userId}
        order by created_at desc
        limit #{limit}
    </select>
</mapper>


<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boboboom.jxc.identity.infrastructure.persistence.mapper.GroupMapper">

    <resultMap id="GroupDOResultMap" type="com.boboboom.jxc.identity.infrastructure.persistence.dataobject.GroupDO">
        <id property="id" column="id"/>
        <result property="groupCode" column="group_code"/>
        <result property="groupName" column="group_name"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="GroupStoreSummaryMap" type="com.boboboom.jxc.identity.infrastructure.persistence.query.GroupStoreSummary">
        <id property="id" column="id"/>
        <result property="groupCode" column="group_code"/>
        <result property="groupName" column="group_name"/>
        <result property="status" column="status"/>
        <result property="storeCount" column="store_count"/>
    </resultMap>

    <sql id="GroupColumns">
        id, group_code, group_name, status, remark, created_at, updated_at
    </sql>

    <select id="selectGroupStoreSummary" resultMap="GroupStoreSummaryMap">
        select g.id,
               g.group_code,
               g.group_name,
               g.status,
               count(s.id) as store_count
        from sys_group g
                 left join sys_store s on s.group_id = g.id
        <where>
            <if test="status != null and status != ''">
                g.status = #{status}
            </if>
        </where>
        group by g.id, g.group_code, g.group_name, g.status
        order by g.id desc
    </select>
</mapper>


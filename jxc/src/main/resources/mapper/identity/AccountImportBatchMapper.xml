<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boboboom.jxc.identity.infrastructure.persistence.mapper.AccountImportBatchMapper">

    <resultMap id="AccountImportBatchDOResultMap" type="com.boboboom.jxc.identity.infrastructure.persistence.dataobject.AccountImportBatchDO">
        <id property="id" column="id"/>
        <result property="batchNo" column="batch_no"/>
        <result property="sourceSystem" column="source_system"/>
        <result property="mqTopic" column="mq_topic"/>
        <result property="mqMessageKey" column="mq_message_key"/>
        <result property="totalCount" column="total_count"/>
        <result property="successCount" column="success_count"/>
        <result property="ignoredCount" column="ignored_count"/>
        <result property="failedCount" column="failed_count"/>
        <result property="processStatus" column="process_status"/>
        <result property="startedAt" column="started_at"/>
        <result property="finishedAt" column="finished_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectRecentBatches" resultMap="AccountImportBatchDOResultMap">
        select id, batch_no, source_system, mq_topic, mq_message_key, total_count, success_count,
               ignored_count, failed_count, process_status, started_at, finished_at, created_at, updated_at
        from ext_account_import_batch
        <where>
            <if test="sourceSystem != null and sourceSystem != ''">
                source_system = #{sourceSystem}
            </if>
        </where>
        order by created_at desc
        limit #{limit}
    </select>
</mapper>

